// utils/metrics.js
const { MongoClient } = require('mongodb');

let db;

async function connectMetrics() {
  const client = new MongoClient(process.env.MONGODB_URI);
  await client.connect();
  db = client.db('video_repository');
  return db.collection('metrics');
}

// Call this when someone watches a video
async function trackView(contentId, category, watchTimeSeconds) {
  const metrics = await connectMetrics();
  const today = new Date();
  
  await metrics.updateOne(
    { 
      date: today.toISOString().split('T')[0], // "2026-07-12"
      contentId: contentId 
    },
    {
      $inc: { 
        views: 1,
        watchTime: watchTimeSeconds
      },
      $setOnInsert: {
        weekNumber: getWeekNumber(today),
        year: today.getFullYear(),
        category: category,
        date: today.toISOString().split('T')[0]
      }
    },
    { upsert: true } // Create if doesn't exist
  );
}

// Call this for likes, shares, etc.
async function trackEngagement(contentId, actionType) {
  const metrics = await connectMetrics();
  const today = new Date().toISOString().split('T')[0];
  
  const updateField = {};
  updateField[actionType] = 1; // e.g., likes: 1
  
  await metrics.updateOne(
    { date: today, contentId: contentId },
    { $inc: updateField },
    { upsert: true }
  );
}

// Helper: Get week number (1-52)
function getWeekNumber(date) {
  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  const dayNum = d.getUTCDay() || 7;
  d.setUTCDate(d.getUTCDate() + 4 - dayNum);
  const yearStart = new Date(Date.UTC(d.getUTCFullYear(),0,1));
  return Math.ceil((((d - yearStart) / 86400000) + 1)/7);
}

module.exports = { trackView, trackEngagement };
